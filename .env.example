# ============================================================================
# SeeWeeS Multi-Agent Dispatch System — environment template
# Copy this file to `.env` (`cp .env.example .env`) and fill in your keys.
# ============================================================================

# ---- Required ----------------------------------------------------------------
# Used by langchain_openai for all 6 GPT agents (Context, Ops, Planner, Audit,
# Allocator, Report). Free-tier accounts work; the system uses gpt-4.1-mini.
OPENAI_API_KEY=""


# ---- Optional: LangSmith tracing --------------------------------------------
# Tracing visualises every LLM call and the full graph execution at
# https://smith.langchain.com. Leave LANGCHAIN_TRACING_V2 set to "false" until
# you have a valid LANGCHAIN_API_KEY, otherwise the run will print 403 errors.
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=""
LANGCHAIN_PROJECT=MSBA_AI_Agents_Demo
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com


# ---- Optional: email the report ---------------------------------------------
# Leave REPORT_EMAIL_TO empty to skip the email step entirely. The pipeline
# also skips it if any SMTP variable is missing, and never crashes the run on
# auth failure (it logs and continues).
#
# Pick ONE provider block below; do NOT configure both — python-dotenv reads
# only the first occurrence of duplicate keys.

# Zoho SMTP (app password):
# SMTP_HOST=smtp.zoho.com
# SMTP_PORT=465
# SMTP_USER=you@zohomail.com
# SMTP_PASSWORD=your-app-password

# Gmail SMTP (app password — not your Google account password):
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_USER=you@gmail.com
# SMTP_PASSWORD=your-app-password

REPORT_EMAIL_TO=


# ---- Optional: weather settings ---------------------------------------------
# Multi-corridor mode reads waypoints from CORRIDOR_WAYPOINTS in src/graph.py
# (authoritative, hardcoded from Playbook v0.2 Section 3.2) and does NOT use
# WEATHER_LAT / WEATHER_LON. The lat/lon fallback below is only used by the
# legacy single-location path if you wire it back in.
WEATHER_TZ=America/New_York
# WEATHER_LAT=40.7282
# WEATHER_LON=-74.0776
